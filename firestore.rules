rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the business
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if user has active subscription
    function hasActiveSubscription(userId) {
      let subscriptionPath = /databases/$(database)/documents/subscriptions/$(userId);
      // If subscription doesn't exist yet, allow access (for initial setup)
      return !exists(subscriptionPath) ? true :
             get(subscriptionPath).data.status == 'active' &&
             get(subscriptionPath).data.accessBlocked == false;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper function to check if user is a reseller (by UID or by email)
    function isReseller(resellerId) {
      // Check if user's UID matches the resellerId
      return request.auth.uid == resellerId ||
             // Or check if user's email matches the reseller's email
             (exists(/databases/$(database)/documents/resellers/$(resellerId)) &&
              get(/databases/$(database)/documents/resellers/$(resellerId)).data.email == request.auth.token.email);
    }

    // Helper function to check access (admin OR active subscription)
    function hasAccess(userId) {
      return isAdmin() || hasActiveSubscription(userId);
    }

    // Helper function to check if current user is a sub-user of a specific owner
    function isSubUserOfOwner(ownerId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.ownerId == ownerId && userDoc.data.isActive == true;
    }

    // Subscriptions collection
    match /subscriptions/{userId} {
      // Users can read their own subscription, admins can read all
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Sub-usuarios pueden leer la suscripción de su owner (para heredar features)
      allow read: if isAuthenticated() && isSubUserOfOwner(userId);
      // Resellers pueden leer suscripciones de clientes que crearon (verificar por UID o email)
      allow read: if isAuthenticated() && resource.data.resellerId != null && isReseller(resource.data.resellerId);
      // Users can create their own subscription (for trial), admins can modify any
      allow create: if isAuthenticated() && isOwner(userId);
      // Admin: necesario para que el onboarding desde el panel admin
      // (AdminCreateAccount → registerBusinessAsAdmin) cree la suscripción de
      // prueba del nuevo negocio sin que el dueño tenga que loguearse primero.
      allow create: if isAdmin();
      // Resellers pueden crear suscripciones para sus clientes (verificar que el resellerId en los datos coincida)
      allow create: if isAuthenticated() && request.resource.data.resellerId != null && isReseller(request.resource.data.resellerId);
      // Only admins can update/delete subscriptions
      allow update, delete: if isAdmin();
      // Resellers pueden actualizar suscripciones de sus clientes, pero NO campos financieros/sensibles
      allow update: if isAuthenticated()
        && resource.data.resellerId != null
        && isReseller(resource.data.resellerId)
        && request.resource.data.currentPeriodEnd == resource.data.currentPeriodEnd
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.limits == resource.data.limits
        && request.resource.data.resellerId == resource.data.resellerId;
    }

    // Admins collection (lista de UIDs de administradores)
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Solo se gestiona manualmente desde consola Firebase
    }

    // Config collection (configuración del sistema)
    match /config/{configId} {
      // Solo admins pueden leer/escribir configuración del sistema
      allow read, write: if isAdmin();
    }

    // AppConfig (versión publicada de la app para el aviso "actualiza desde la
    // tienda"). Lectura para cualquier usuario logueado; escritura solo admin.
    match /appConfig/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // AdminStats collection (estadísticas para panel de admin)
    match /adminStats/{docId} {
      // Solo admins pueden leer/escribir estadísticas
      allow read, write: if isAdmin();
    }

    // Settings collection (configuración global como tiers de resellers)
    match /settings/{settingId} {
      // Usuarios autenticados pueden leer configuración de tiers (necesario para resellers)
      allow read: if isAuthenticated();
      // Solo admins pueden escribir
      allow write: if isAdmin();
    }

    // Vendedores collection (agentes de venta)
    match /vendedores/{vendedorId} {
      // Solo admins pueden crear/editar/eliminar vendedores
      allow read, write: if isAdmin();
      // Usuarios autenticados pueden leer (para mostrar datos de pago en suspensión)
      allow read: if isAuthenticated();
    }

    // Resellers collection
    match /resellers/{resellerId} {
      // Admins pueden leer/escribir cualquier reseller
      allow read, write: if isAdmin();

      // Resellers pueden leer sus propios datos (por UID)
      allow read: if isAuthenticated() && isOwner(resellerId);
      // Resellers pueden actualizar sus propios datos, pero NO el balance ni totalSpent
      allow update: if isAuthenticated() && isOwner(resellerId)
        && request.resource.data.balance == resource.data.balance
        && request.resource.data.totalSpent == resource.data.totalSpent;

      // Usuarios autenticados pueden leer si su email coincide con el del reseller
      // Esto permite que resellers creados con docId diferente al uid puedan acceder
      allow read: if isAuthenticated() && resource.data.email == request.auth.token.email;

      // Para update: verificar que el email del documento existente coincida con el del usuario
      allow update: if isAuthenticated() && resource.data.email == request.auth.token.email;

      // Lectura pública para branding en página de login (detección por subdomain/customDomain)
      // Esto permite que usuarios no autenticados vean el branding del reseller en la página de login
      allow read: if true;
    }

    // Reseller Transactions collection
    match /resellerTransactions/{transactionId} {
      // Resellers pueden leer sus transacciones (verificar por UID o email)
      allow read: if isAuthenticated() && resource.data.resellerId != null && isReseller(resource.data.resellerId);
      // Resellers pueden crear transacciones (verificar que el resellerId en los datos coincida)
      allow create: if isAuthenticated() && request.resource.data.resellerId != null && isReseller(request.resource.data.resellerId);
      // Admins pueden leer/escribir cualquier transacción
      allow read, write: if isAdmin();
    }

    // Users collection (para gestión de usuarios y permisos)
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer su propio documento
      allow get: if isAuthenticated() && isOwner(userId);

      // Business Owners pueden LISTAR usuarios de SU negocio. Antes era
      // `if isAuthenticated()` → cualquier autenticado podía enumerar TODA la
      // colección /users (emails, roles, tenant de todos). Ahora se obliga a que
      // la query esté acotada al propio tenant:
      //  - `ownerId == uid` (el dueño lista a sus sub-usuarios)
      //  - `businessId == uid` (flujo de Settings/Yape)
      //  - `ownerId == (mi ownerId)` → un SUB-USUARIO lista a sus COMPAÑEROS del
      //    mismo negocio (necesario para el planificador de Horarios). Sigue
      //    acotado al propio tenant: no puede listar otros negocios.
      // Admin lista todo. Firestore rechaza las queries no acotadas a estos filtros.
      allow list: if isAdmin() || (isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.businessId == request.auth.uid ||
        resource.data.ownerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownerId
      ));

      // Admins pueden leer cualquier usuario
      allow read: if isAdmin();

      // Permitir crear documentos en dos casos:
      // 1. Usuario creando su propio documento de Business Owner (userId == auth.uid).
      //    SEGURIDAD: el ownerId del self-create debe ser uno mismo o estar ausente, para
      //    que nadie se cree como sub-usuario de OTRO negocio (escalación de tenant vía create,
      //    p.ej. un sub-usuario eliminado recreando su doc con ownerId ajeno).
      // 2. Business Owner creando sub-usuario de SU negocio (ownerId == auth.uid).
      allow create: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.get('ownerId', request.auth.uid) == request.auth.uid) ||
        request.resource.data.ownerId == request.auth.uid
      );

      // Los usuarios pueden actualizar su propio documento, PERO NO los campos de
      // seguridad: no pueden cambiar de tenant (ownerId), reactivarse (isActive), ni
      // auto-otorgarse rol/permisos. Sin esto, un sub-usuario (cajero/mozo) escalaba a
      // dueño de cualquier otro negocio editando su propio doc. (El owner SÍ gestiona a
      // sus sub-usuarios por la regla de abajo, que valida resource.data.ownerId == auth.uid.)
      allow update: if isAuthenticated() && isOwner(userId)
        && request.resource.data.get('ownerId', null) == resource.data.get('ownerId', null)
        && request.resource.data.get('isActive', null) == resource.data.get('isActive', null)
        && request.resource.data.get('role', null) == resource.data.get('role', null)
        && request.resource.data.get('allowedPages', null) == resource.data.get('allowedPages', null)
        && request.resource.data.get('allowedWarehouses', null) == resource.data.get('allowedWarehouses', null)
        && request.resource.data.get('allowedDocumentTypes', null) == resource.data.get('allowedDocumentTypes', null)
        && request.resource.data.get('allowedPaymentMethods', null) == resource.data.get('allowedPaymentMethods', null)
        && request.resource.data.get('isPlatformAdmin', false) == resource.data.get('isPlatformAdmin', false);

      // Business Owners pueden actualizar usuarios que crearon
      allow update: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;

      // Admins pueden hacer cualquier cosa
      allow write: if isAdmin();

      // Business Owners pueden eliminar usuarios que crearon
      allow delete: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;

      // Subcollection: FCM Tokens (para notificaciones push)
      match /fcmTokens/{tokenId} {
        // Los usuarios pueden leer, escribir y eliminar sus propios tokens FCM
        allow read, write: if isAuthenticated() && isOwner(userId);
        // Admins pueden leer todos los tokens (para collectionGroup en campañas push)
        allow read: if isAdmin();
      }
    }

    // Push Campaigns collection (campañas de notificaciones push)
    match /pushCampaigns/{campaignId} {
      // Solo admins pueden leer/escribir campañas
      allow read, write: if isAdmin();
    }

    // CollectionGroup: FCM Tokens (para que admins puedan hacer collectionGroup query)
    match /{path=**}/fcmTokens/{tokenId} {
      allow read: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read/write their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Crear: solo para uno mismo, o admin (notificaciones de pago/renovación que
      // el panel admin genera para el dueño). Antes `if isAuthenticated()` permitía
      // crear notificaciones a nombre de CUALQUIER usuario (spam). Los resellers no
      // crean notificaciones client-side; el servidor usa Admin SDK (omite reglas).
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Helper function to check if user is sub-user of business owner
    function isSubUserOf(ownerId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.ownerId == ownerId && userDoc.data.isActive == true;
    }

    // Helper function to check if user can access business data
    // Returns true if: user is owner OR user is active sub-user of owner
    function canAccessBusiness(userId) {
      return isOwner(userId) || isSubUserOf(userId);
    }

    // Businesses (Negocios)
    // Cada usuario tiene un solo negocio con su userId como ID
    // IMPORTANTE: Los administradores tienen acceso sin importar su suscripción
    // Sub-usuarios (employees) pueden acceder a los datos del Business Owner
    match /businesses/{userId} {
      // Admins pueden leer/escribir cualquier negocio
      allow read, write: if isAdmin();
      // Owners y sub-usuarios pueden acceder a su propio negocio si tienen acceso activo
      allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

      // Resellers pueden crear negocios para sus clientes.
      // SEGURIDAD: antes cualquier autenticado podía crear businesses/{cualquierUID}
      // con solo poner createdByReseller:true + un resellerId arbitrario (squatting/
      // inyección). Ahora se valida que el que crea SEA ese reseller (isReseller).
      allow create: if isAuthenticated() &&
                       request.resource.data.createdByReseller == true &&
                       request.resource.data.resellerId != null &&
                       isReseller(request.resource.data.resellerId);

      // Lectura pública para catálogo - permite buscar negocios por catalogSlug
      // Para que funcione en usuarios no autenticados, permitimos lectura pública
      // pero solo de negocios con catalogEnabled == true
      // El cliente filtrará adicionalmente por catalogSlug
      allow read: if resource.data.catalogEnabled == true;

      // Lectura pública para Libro de Reclamaciones - permite buscar negocios por complaintsBookSlug
      // Solo negocios con complaintsBookEnabled == true pueden ser consultados públicamente
      allow read: if resource.data.complaintsBookEnabled == true;

      // Subcollection: Invoices (Facturas/Boletas)
      match /invoices/{invoiceId} {
        // Admins pueden leer todas las facturas
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Customers (Clientes)
      match /customers/{customerId} {
        // Admins pueden leer todos los clientes
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

        // Subcollection: Medical History (Historial Médico - modo veterinaria)
        match /medicalHistory/{recordId} {
          allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
          allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        }

        // Subcollection: Vaccinations (Vacunas - modo veterinaria)
        match /vaccinations/{vaccinationId} {
          allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
          allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        }

        // Subcollection: Recurring Services (Servicios Recurrentes - modo veterinaria)
        match /recurringServices/{serviceId} {
          allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
          allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        }
      }

      // Subcollection: Products (Productos)
      match /products/{productId} {
        // Admins pueden leer y escribir todos los productos (necesario para
        // onboarding masivo desde el panel admin: AdminCreateAccount importa los
        // productos del Excel al negocio recién creado).
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        // Lectura pública para catálogo - permitir queries cuando el negocio tiene catálogo habilitado
        // La query debe filtrar por catalogVisible==true en el cliente
        allow read: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true;
      }

      // Subcollection: Categories (Categorías)
      match /categories/{categoryId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        // Lectura pública para catálogo
        allow read: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true;
      }

      // Subcollection: Cash Register Sessions (Sesiones de Caja)
      match /cashSessions/{sessionId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Cash Movements (Movimientos de Caja)
      match /cashMovements/{movementId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Suppliers (Proveedores)
      match /suppliers/{supplierId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Purchases (Compras)
      match /purchases/{purchaseId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Quotations (Cotizaciones)
      match /quotations/{quotationId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Purchase Orders (Órdenes de Compra a proveedores)
      match /purchaseOrders/{orderId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Warehouses (Almacenes)
      match /warehouses/{warehouseId} {
        // Admins pueden leer/escribir cualquier almacén
        allow read, write: if isAdmin();
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Stock Movements (Movimientos de Inventario)
      match /stockMovements/{movementId} {
        // Admin: necesario para crear movimientos de stock inicial durante el
        // onboarding masivo de productos desde el panel admin.
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Stock Backups (respaldo previo de las herramientas masivas
      // de inventario — Verificar/Corregir stock — y su botón "Revertir").
      // SOLO EL DUEÑO: esas herramientas son solo-dueño por diseño (blindaje Fase 1).
      // Sin este match el backup fallaba en silencio para todos ("Missing or
      // insufficient permissions"): en estas reglas, sin match explícito = denegado.
      match /stockBackups/{backupId} {
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated() && isOwner(userId) && hasAccess(userId);

        match /chunks/{chunkId} {
          allow read, write: if isAdmin();
          allow read, write: if isAuthenticated() && isOwner(userId) && hasAccess(userId);
        }
      }

      // Subcollection: Tables (Mesas - para modo restaurante)
      match /tables/{tableId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

        // Lectura pública de mesas para carta digital (buscar mesa por número)
        allow read: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true;

        // Permitir actualización pública de mesas desde carta digital (ocupar mesa al hacer pedido)
        // Solo permite cambiar status, currentOrder, startTime, amount, updatedAt
        allow update: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'currentOrder', 'startTime', 'amount', 'updatedAt']);
      }

      // Subcollection: Waiters (Mozos - para modo restaurante)
      match /waiters/{waiterId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Mesas cerradas sin comprobante (auditoría)
      match /tableCloseWithoutReceipt/{recordId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Snapshots de precuentas (auditoría)
      match /precuentaSnapshots/{snapshotId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Órdenes modificadas después de precuenta (auditoría)
      match /orderModifiedAfterPrecuenta/{recordId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Sellers (Vendedores)
      match /sellers/{sellerId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Orders (Órdenes - para modo restaurante)
      match /orders/{orderId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

        // Permitir creación pública de órdenes desde carta digital
        // Solo si el negocio tiene catálogo habilitado y el pedido viene de menu_digital
        allow create: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true
                      && request.resource.data.source == 'menu_digital'
                      && request.resource.data.orderType != null
                      && request.resource.data.items != null;

        // Permitir lectura pública de órdenes cuando el negocio tiene catálogo habilitado
        // Necesario para mostrar resumen de orden al cliente que escanea QR de mesa
        allow get: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true;

        // Permitir actualización pública limitada desde carta digital
        // Solo campos permitidos: tableId, items, subtotal, tax, total, updatedAt
        allow update: if get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['tableId', 'items', 'subtotal', 'tax', 'total', 'updatedAt']);
      }

      // Subcollection: Counters (Contadores - para números secuenciales)
      match /counters/{counterId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

        // Permitir lectura y escritura pública de contadores de órdenes para carta digital
        // Solo para contadores que empiezan con "orders-" (ej: orders-2026-01-27)
        allow read, write: if counterId[0:7] == 'orders-'
                          && get(/databases/$(database)/documents/businesses/$(userId)).data.catalogEnabled == true;
      }

      // Subcollection: Emission Config (Configuración de emisión electrónica)
      match /emissionConfig/{configId} {
        // Owners y sub-usuarios pueden leer configuración para calcular IGV
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        // Solo admins pueden escribir (se configura desde panel admin)
        allow write: if isAdmin();
      }

      // Subcollection: Secrets (credenciales de emisión SUNAT/QPse: certificado .p12,
      // contraseñas, claves SOL). Se mueven aquí desde el doc top-level (que es de
      // lectura PÚBLICA cuando el catálogo/libro está activo). NUNCA público ni
      // sub-usuarios: solo el dueño (Settings) y el admin (panel) las leen/escriben;
      // el servidor las lee con Admin SDK (que omite estas reglas).
      match /secrets/{secretId} {
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Subcollection: Ingredients (Ingredientes - para modo restaurante)
      match /ingredients/{ingredientId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Recipes (Recetas - para modo restaurante)
      match /recipes/{recipeId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Ingredient Purchases (Compras de Ingredientes - para modo restaurante)
      match /ingredientPurchases/{purchaseId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Stock Movements for Ingredients (Movimientos de Stock de Ingredientes)
      match /stockMovements/{movementId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Expenses (Gastos del negocio)
      match /expenses/{expenseId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Laboratories (Laboratorios - para modo farmacia)
      match /laboratories/{laboratoryId} {
        // Admin: necesario durante onboarding (modo farmacia) para crear los
        // laboratorios derivados del Excel importado.
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Properties (Propiedades - para modo inmobiliaria)
      match /properties/{propertyId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Operations (Operaciones de venta/alquiler - para modo inmobiliaria)
      match /operations/{operationId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Agents (Agentes/Corredores - para modo inmobiliaria)
      match /agents/{agentId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Dispatch Guides (Guías de Remisión Electrónicas - Remitente)
      match /dispatchGuides/{guideId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Carrier Dispatch Guides (Guías de Remisión Electrónicas - Transportista)
      match /carrierDispatchGuides/{guideId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Inventory Counts (Sesiones de Recuento de Inventario)
      match /inventoryCounts/{countId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Loans (Préstamos bancarios y de terceros)
      match /loans/{loanId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Financial Movements (Movimientos Financieros - Flujo de Caja)
      match /financialMovements/{movementId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Branches (Sucursales - configuradas por admin)
      match /branches/{branchId} {
        // Admins pueden leer/escribir cualquier sucursal
        allow read, write: if isAdmin();
        // Owners y sub-usuarios pueden leer sucursales de su negocio
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        // Owner del negocio puede ACTUALIZAR sus sucursales (configurar asistencia,
        // geofence, token QR, período de gracia, etc. desde Control de Asistencia).
        // Create/delete siguen siendo solo admin (se configuran desde panel admin).
        allow update: if isAuthenticated() && isOwner(userId);
      }

      // Subcollection: Settings (Configuraciones del negocio - Yape, etc.)
      match /settings/{settingId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Yape Payments (Pagos detectados de Yape)
      match /yapePayments/{paymentId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Training Certificates (Certificados de Capacitación)
      match /certificates_training/{certificateId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Operability Certificates (Certificados de Operatividad)
      match /certificates_operability/{certificateId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Productions (Producciones - transformar insumos en producto terminado)
      match /productions/{productionId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Mass Transfers (Transferencias masivas entre almacenes)
      match /massTransfers/{transferId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Motoristas (Repartidores)
      match /motoristas/{motoristaId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Deliveries (Envíos/Entregas)
      match /deliveries/{deliveryId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Rooms (Habitaciones - para modo hotel)
      match /hotelRooms/{roomId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Reservations (Reservas - para modo hotel)
      match /hotelReservations/{reservationId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Services (Servicios - piscina, juegos, etc.)
      match /hotelServices/{serviceId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Folio Charges (Cargos al folio del huésped)
      match /hotelFolioCharges/{chargeId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Night Audits (Auditorías nocturnas)
      match /hotelNightAudits/{auditId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Hotel Seasonal Rates (Tarifas por temporada)
      match /hotelSeasonalRates/{rateId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Warehouse Exits (Salidas de almacén - para modo logística)
      match /warehouseExits/{exitId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Warehouse Returns (Retornos a almacén - para modo logística)
      match /warehouseReturns/{returnId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Projects (Proyectos/Obras - para modo logística)
      match /projects/{projectId} {
        allow read: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Appointments (Citas Veterinarias)
      match /appointments/{appointmentId} {
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Attendance (Control de Asistencia del Personal)
      // Path: businesses/{userId}/attendance/{recordId}
      // Lo escriben los sub-usuarios al marcar asistencia por QR o manualmente,
      // y el dueño/admin para correcciones manuales o cierres automáticos.
      match /attendance/{recordId} {
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Shift Templates (Plantillas de turno - módulo Personal Capa 2)
      // Plantillas reusables para asignar horarios. Solo owner/admin las gestiona;
      // sub-usuarios las leen para ver el detalle de su turno asignado.
      match /shiftTemplates/{templateId} {
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Schedules (Horarios semanales - módulo Personal Capa 2)
      // Path: businesses/{userId}/schedules/{userId_YYYY_WW}
      // El owner los crea/edita; los sub-usuarios leen los suyos para el portal.
      match /schedules/{scheduleId} {
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Time-Off Requests (Solicitudes de vacaciones/permisos - Capa 3)
      // El owner aprueba/rechaza; los sub-usuarios podrán crear las suyas en
      // la Capa 4 (portal del empleado).
      match /timeOffRequests/{requestId} {
        allow read: if isAdmin() || (isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId));
        allow write: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);
      }

      // Subcollection: Complaints (Libro de Reclamaciones)
      match /complaints/{complaintId} {
        // El dueño del negocio puede leer y actualizar todos los reclamos
        allow read, update: if isAuthenticated() && canAccessBusiness(userId) && hasAccess(userId);

        // Lectura pública para consultar por código de seguimiento (si el libro está habilitado)
        allow read: if get(/databases/$(database)/documents/businesses/$(userId)).data.complaintsBookEnabled == true;

        // Creación pública (si el libro está habilitado y datos válidos)
        allow create: if get(/databases/$(database)/documents/businesses/$(userId)).data.complaintsBookEnabled == true
                      && request.resource.data.status == 'pending'
                      && request.resource.data.trackingCode != null;

        // No se permite eliminar reclamos (obligación legal de conservarlos 2 años)
        allow delete: if false;
      }
    }
  }
}
